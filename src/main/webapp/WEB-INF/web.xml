<?xml version="1.0" encoding="UTF-8"?>
<!--
    [CORRIGIDO] Namespace trocado de Jakarta EE 5.0 (Tomcat 10+) para Java EE 4.0 (Tomcat 9)
    para ser compatível com as dependências javax.servlet do pom.xml.
    Se o grupo usar Tomcat 10+, troque o namespace de volta para jakarta.ee e
    atualize os imports nos Servlets de javax.servlet.* para jakarta.servlet.*
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>TaskManager</display-name>

    <!-- [CORRIGIDO] welcome-file aponta para index.jsp que redireciona para /login -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ======================================================= -->
    <!-- SERVLETS                                                 -->
    <!-- [CORRIGIDO] Pacote era "controller.*" — agora usa       -->
    <!--             "com.taskmanager.controller.*"               -->
    <!-- ======================================================= -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.taskmanager.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CadastroServlet</servlet-name>
        <servlet-class>com.taskmanager.controller.CadastroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CadastroServlet</servlet-name>
        <url-pattern>/cadastro</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TarefaServlet</servlet-name>
        <servlet-class>com.taskmanager.controller.TarefaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TarefaServlet</servlet-name>
        <url-pattern>/tarefa</url-pattern>
    </servlet-mapping>

    <!-- [ADICIONADO] Dashboard também mapeado no TarefaServlet -->
    <servlet-mapping>
        <servlet-name>TarefaServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.taskmanager.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Páginas de erro -->
    <error-page>
        <error-code>404</error-code>
        <location>/login</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/login</location>
    </error-page>

</web-app>
